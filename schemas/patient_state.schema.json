{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://dialogue-safety.example.com/schemas/patient_state.schema.json",
  "title": "PatientState",
  "description": "Strict patient_state contract for dialogue-safety-rules v4.2.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["patient_id", "current_medications", "disease_codes"],
  "properties": {
    "patient_id": {
      "type": "string",
      "minLength": 1,
      "description": "Synthetic patient identifier."
    },
    "current_medications": {
      "type": "array",
      "description": "Strict list of medication entries; non-objects are rejected.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drug_id", "drug_name", "status"],
        "properties": {
          "drug_id": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical drug identifier; validated against the alias table."
          },
          "drug_name": {
            "type": "string",
            "minLength": 1,
            "description": "Display name; must map to the same drug_id."
          },
          "status": {
            "type": "string",
            "enum": ["active", "held", "stopped", "completed", "unknown"],
            "description": "Medication status; unknown is accepted but flagged."
          },
          "dose_value": {
            "type": "number",
            "minimum": 0,
            "description": "Numeric dose (cannot be negative or NaN)."
          },
          "dose_unit": {
            "type": "string",
            "enum": ["mcg", "mg", "g", "IU"],
            "description": "Dose unit; unknown units raise REVIEW."
          },
          "frequency_per_day": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Frequency in doses per day."
          },
          "route": {
            "type": "string",
            "enum": ["oral", "iv", "im", "sc", "inhale", "topical", "other"],
            "description": "Route of administration."
          }
        }
      }
    },
    "disease_codes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "description": "Canonical disease codes; unknown values force REVIEW."
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional structured measurements.",
      "properties": {
        "egfr": {"$ref": "#/definitions/measurement"},
        "systolic_bp": {"$ref": "#/definitions/measurement"},
        "diastolic_bp": {"$ref": "#/definitions/measurement"},
        "glucose": {"$ref": "#/definitions/measurement"},
        "serum_potassium": {"$ref": "#/definitions/measurement"},
        "uric_acid": {"$ref": "#/definitions/measurement"}
      }
    },
    "clinical_flags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "has_chd": {"type": ["boolean", "null"]},
        "kidney_stone_history": {"type": ["boolean", "null"]},
        "gout_acute_flare": {"type": ["boolean", "null"]},
        "pregnancy": {"type": ["boolean", "null"]}
      }
    },
    "allergies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "egfr": {
      "type": "number",
      "description": "Legacy direct field; the engine normalizes into measurements.egfr.value."
    },
    "latest_systolic_bp_mmHg": {"type": "number"},
    "latest_glucose_mmol_l": {"type": "number"},
    "serum_potassium_mmol_l": {"type": "number"}
  },
  "definitions": {
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "observed_at", "source", "confirmed"],
      "properties": {
        "value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "observed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp with timezone."
        },
        "source": {
          "type": "string",
          "enum": ["laboratory", "home_measurement", "clinic_visit", "wearable", "patient_self_report", "other"]
        },
        "confirmed": {"type": "boolean"}
      }
    }
  }
}